// openclaw.json — OpenClaw gateway configuration
// https://github.com/YOUR_USERNAME/openclaw-pi-setup
//
// This is JSON5 — comments and trailing commas are allowed.
// Substitute ${TAILSCALE_HOSTNAME} before deploying (done by setup-openclaw.sh).
// Secrets (bot token, API key) are NOT in this file — they come from
// /etc/openclaw/secrets.env via the systemd EnvironmentFile directive.

{
  // ── Gateway ─────────────────────────────────────────────────────────────────
  // Bind to loopback only — the gateway is not exposed to the LAN directly.
  // Tailscale Serve proxies HTTPS from your private tailnet to 127.0.0.1:18789.
  // Access is limited to devices on your Tailscale network.
  "gateway": {
    "bind": "loopback",
    "port": 18789,
    "tailscale": {
      "mode": "serve"
    }
  },

  // ── Agents ──────────────────────────────────────────────────────────────────
  // Default model and token budget for all agents.
  // Haiku is the primary model (fast, cheap on Pi 4).
  // Sonnet is the fallback for tasks that require more capability.
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-haiku-4-5-20251001",
        "fallbacks": ["anthropic/claude-sonnet-4-6"]
      },
      "maxTokens": 1024,
      // non-main sandbox: agent tools run in a sandboxed subprocess,
      // protecting the host environment from unintended side effects.
      "sandbox": {
        "mode": "non-main"
      }
    }
  },

  // ── Channels ─────────────────────────────────────────────────────────────────
  // Telegram channel. The bot token is read from the TELEGRAM_BOT_TOKEN
  // environment variable (set in /etc/openclaw/secrets.env via systemd
  // EnvironmentFile) — it does not appear in this config file.
  // dmPolicy "pairing" requires explicit owner approval before any new user
  // can send messages to the bot. Fail-closed by default.
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "pairing"
    }
  },

  // ── Tools ───────────────────────────────────────────────────────────────────
  // Use the "minimal" profile as a base — this disables browser automation,
  // canvas, and voice which are not useful on a headless Pi and would waste
  // resources or expand the attack surface.
  "tools": {
    "profile": "minimal"
  }
}
